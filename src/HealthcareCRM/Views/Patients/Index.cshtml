@model IEnumerable<HealthcareCRM.Models.Patient>

@{
    ViewData["Title"] = "Patient Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary fw-bold mb-1">Patients Directory</h2>
            <p class="text-muted small mb-0">Manage and view all registered healthcare system patients.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary px-4 shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Register New Patient
        </a>
    </div>

    <div class="card border-0 shadow-sm mb-4 bg-light">
        <div class="card-body p-3">
            <form asp-action="Index" method="get" class="row g-2">
                <div class="col-md-9">
                    <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" 
                           class="form-control" placeholder="Search by patient name or email id..." />
                </div>
                <div class="col-md-3 d-grid">
                    <button type="submit" class="btn btn-dark">
                        <i class="bi bi-search me-1"></i> Search
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-secondary small text-uppercase">
                        <tr>
                            <th class="ps-4">Full Name</th>
                            <th>Contact Info</th>
                            <th>Date of Birth</th>
                            <th>Gender</th>
                            <th>Address</th>
                            <th class="pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox display-6 d-block mb-2 text-secondary"></i>
                                    No patient records found matching the criteria.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold text-dark">@item.FullName</td>
                                    <td>
                                        <div class="small">@item.Email</div>
                                        <div class="text-muted min-small">@item.PhoneNumber</div>
                                    </td>
                                    <td>@item.DateOfBirth.ToString("dd MMM yyyy")</td>
                                    <td>
                                        <span class="badge @(item.Gender == "Male" ? "bg-blue-subtle text-primary" : "bg-pink-subtle text-danger") px-2.5 py-1.5 rounded-pill small">
                                            @item.Gender
                                        </span>
                                    </td>
                                    <td class="text-truncate" style="max-width: 200px;">@item.Address</td>
                                    <td class="pe-4">
                                        <a asp-action="GetPatientJson" asp-route-id="@item.Id" target="_blank" class="btn btn-sm btn-outline-secondary py-1 px-2">
                                            <i class="bi bi-code-json"></i> View JSON Response
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>