@model HealthcareCRM.Models.Patient

@{
    ViewData["Title"] = "Register Patient";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="mb-3">
                <a asp-action="Index" class="text-decoration-none text-secondary small">
                    <i class="bi bi-arrow-left me-1"></i> Back to Directory
                </a>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h3 class="text-dark fw-bold mb-1">Patient Onboarding Form</h3>
                    <p class="text-muted small mb-0">Fill in the official details below to register a new patient account.</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-12">
                                <label asp-for="FullName" class="form-label small fw-bold text-secondary">Full Name</label>
                                <input asp-for="FullName" class="form-control" placeholder="John Doe" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label small fw-bold text-secondary">Email Address</label>
                                <input asp-for="Email" class="form-control" type="email" placeholder="johndoe@example.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="PhoneNumber" class="form-label small fw-bold text-secondary">Phone Number</label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="+923001234567" />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="DateOfBirth" class="form-label small fw-bold text-secondary">Date of Birth</label>
                                <input asp-for="DateOfBirth" class="form-control" type="date" />
                                <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Gender" class="form-label small fw-bold text-secondary">Gender</label>
                                <select asp-for="Gender" class="form-select">
                                    <option value="">Choose gender...</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                    <option value="Other">Other</option>
                                </select>
                                <span asp-validation-for="Gender" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="Address" class="form-label small fw-bold text-secondary">Residential Address</label>
                                <input asp-for="Address" class="form-control" placeholder="Street Address, City, Country" />
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary px-4 shadow-sm">Save Patient Record</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}