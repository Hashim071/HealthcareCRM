@model IEnumerable<HealthcareCRM.Models.Doctor>

@{
    ViewData["Title"] = "Doctor & Staff Directory";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">Doctor & Staff Directory</h2>
        <a asp-action="Create" class="btn btn-success px-4 py-2 fw-semibold shadow-sm">
            <i class="bi bi-person-plus"></i> Add New Doctor
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-2">
                <div class="col-md-9">
                    <input type="text" name="searchString" class="form-control py-2" placeholder="Search by name or specialization..." value="@Context.Request.Query["searchString"]" />
                </div>
                <div class="col-md-3 d-grid">
                    <button type="submit" class="btn btn-primary fw-semibold py-2">
                        <i class="bi bi-search"></i> Filter Directory
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3 text-secondary fw-semibold">Doctor Name</th>
                            <th class="py-3 text-secondary fw-semibold">Specialization</th>
                            <th class="py-3 text-secondary fw-semibold">Email</th>
                            <th class="py-3 text-secondary fw-semibold">Phone Number</th>
                            <th class="py-3 text-secondary fw-semibold">Room/Cabin</th>
                            <th class="pe-4 py-3 text-end text-secondary fw-semibold">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <p class="mb-0 fw-medium">No doctor records matched your search filter criteria.</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold text-dark">@item.Name</td>
                                    <td><span class="badge bg-secondary-subtle text-secondary px-2.5 py-1.5 fw-semibold rounded">@item.Specialization</span></td>
                                    <td>@item.Email</td>
                                    <td>@item.Phone</td>
                                    <td class="fw-medium text-primary">@item.RoomNumber</td>
                                    <td class="pe-4 text-end">
                                        <button class="btn btn-outline-secondary btn-sm rounded px-3" onclick="viewDoctorJson('@item.Id')">
                                            View JSON
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    function viewDoctorJson(id) {
        fetch(`/Doctors/GetDoctorJson/${id}`)
            .then(res => res.json())
            .then(data => {
                alert(JSON.stringify(data, null, 2));
            })
            .catch(err => alert("Error fetching doctor data"));
    }
</script>